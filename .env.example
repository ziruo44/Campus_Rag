QWEN_API_KEY=your_api_key_here
QWEN_MODEL=qwen-turbo
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

CHROMA_PERSIST_DIR=./data/chroma_db
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=768

MAX_ITERATIONS=10
RELEVANCE_THRESHOLD=0.7
TOP_K=5

SERPER_API_KEY=

# Memory settings
MEMORY_MAX_TOKENS=4000
MEMORY_MAX_TURNS=5
MEMORY_SESSION_DIR=./data/memory/sessions
MEMORY_CURRENT_SESSION_FILE=./data/memory/.current_session
MEMORY_RETENTION_DAYS=30
MEMORY_LOCK_TIMEOUT_SECONDS=10
MEMORY_MAX_REFERENCES_PER_THREAD=5
MEMORY_REFERENCE_RECENT_TURNS_LIMIT=1
MEMORY_REFERENCE_SUMMARY_CHAR_LIMIT=500
MEMORY_BACKUP_CORRUPT_FILES=true

# Retrieval cache settings
RETRIEVAL_CACHE_ENABLED=false
RETRIEVAL_CACHE_REDIS_URL=redis://localhost:6379/0
RETRIEVAL_CACHE_TTL_SECONDS=3600
RETRIEVAL_CACHE_KEY_PREFIX=rag:retrieval
RETRIEVAL_CACHE_KNOWLEDGE_BASE_VERSION=major-knowledge-v1
RETRIEVAL_CACHE_MAJOR_KNOWLEDGE_BASE_VERSION=major-knowledge-v1
RETRIEVAL_CACHE_LIFE_GUIDE_KNOWLEDGE_BASE_VERSION=life-guide-v1
RETRIEVAL_CACHE_PROMPT_VERSION=v1
